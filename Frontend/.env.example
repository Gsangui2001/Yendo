# Frontend Yendo — copiá este archivo como .env y completá los valores.
# La ANON key es pública (viaja en el bundle), pero igual va por env var.
# Si faltan estas dos, la app tira error al arrancar (a propósito).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=PEGAR_ANON_KEY_DE_SUPABASE

# URL del backend Express (en producción: la URL del deploy)
VITE_API_URL=http://localhost:3001
