# Backend Yendo — copiá este archivo como .env y completá los valores.
# La SERVICE KEY es secreta: NUNCA va al frontend ni al repo.

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=PEGAR_SERVICE_ROLE_KEY_DE_SUPABASE

# Puerto del API (default 3001)
PORT=3001

# Orígenes permitidos por CORS, separados por coma
FRONTEND_URL=http://localhost:5173
